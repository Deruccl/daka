# ====================================
# 时光印记 TimeMark - 签名配置示例文件
# ====================================
# 使用说明：
# 1. 复制本文件为 keystore.properties（同目录）
# 2. 将真实密钥库信息填入 keystore.properties
# 3. 将密钥库文件（*.jks）放在项目根目录
# 4. 切勿将 keystore.properties 和 *.jks 提交到版本控制
#
# 生成密钥库命令：
#   keytool -genkeypair -v -keystore timemark.jks -alias timemark \
#     -keyalg RSA -keysize 2048 -validity 10000
# ====================================

storeFile=timemark.jks
storePassword=your_store_password
keyAlias=timemark
keyPassword=your_key_password
