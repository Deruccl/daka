<?xml version="1.0" encoding="utf-8"?>
<!--
    JetBrains Mono 字体族配置 (Task 38.1)

    用于数据展示（统计数字、代码等）的等宽字体。

    使用前请下载以下 TTF 文件并放入 app/src/main/res/font/ 目录：
    - jetbrains_mono_regular.ttf (FontWeight.Normal, 400)
    - jetbrains_mono_bold.ttf    (FontWeight.Bold, 700)

    下载地址：https://fonts.google.com/specimen/JetBrains+Mono

    下载后取消注释下方 <font> 元素即可启用。
    未提供 TTF 文件时，应用将自动降级为系统等宽字体（FontFamily.Monospace）。
-->
<font-family xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- <font android:fontStyle="normal" android:fontWeight="400" android:font="@font/jetbrains_mono_regular" /> -->
    <!-- <font android:fontStyle="normal" android:fontWeight="700" android:font="@font/jetbrains_mono_bold" /> -->
</font-family>
